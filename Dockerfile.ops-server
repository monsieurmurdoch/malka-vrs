FROM node:18-alpine

WORKDIR /app

# Install only runtime dependencies; this release line ships prebuilt dist/.
COPY vrs-ops-server/package*.json ./
RUN npm install --omit=dev

COPY vrs-ops-server/dist/ ./dist/
COPY vrs-ops-server/.env.example ./.env.example

# Create data directory for persisted state
RUN mkdir -p /app/data

EXPOSE 3003

CMD ["node", "dist/index.js"]
