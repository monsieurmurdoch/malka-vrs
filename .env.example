# ============================================================
# MalkaVRS Environment Configuration
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================================

# --- REQUIRED ---
# Shared JWT secret used by all servers (vrs-server, ops-server, twilio-server).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
VRS_SHARED_JWT_SECRET=

# Ops server superadmin password (used for initial bootstrap login).
VRS_BOOTSTRAP_SUPERADMIN_PASSWORD=

# --- JITSI BACKEND ---
# Domain used by the local Jitsi stack (matches Prosody XMPP_DOMAIN in docker-compose).
JITSI_DOMAIN=meet.jitsi

# Production deployment helpers (used by docker-compose.prod.yml)
# DOMAIN=staging.example.com
# DROPLET_PUBLIC_IP=203.0.113.10

# --- TWILIO (optional — leave empty to disable phone features) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Public base URL for Twilio status callbacks, including the /twilio mount.
WEBHOOK_BASE_URL=https://app.malkacomm.com/twilio

# --- POSTGRESQL ---
# Primary application database used by vrs-server and ops-server.
# Connection string (used in Docker; override for external PG)
# Runtime traffic goes through PgBouncer; migrations/admin tasks use direct Postgres.
# DATABASE_URL=postgresql://malka:malka@pgbouncer:6432/malka_vrs
# OPS_DATABASE_URL=postgresql://malka:malka@pgbouncer:6432/malka_vrs
# MIGRATION_DATABASE_URL=postgresql://malka:malka@postgres:5432/malka_vrs
# OPS_MIGRATION_DATABASE_URL=postgresql://malka:malka@postgres:5432/malka_vrs
PGUSER=malka
PGPASSWORD=malka
PGDATABASE=malka_vrs
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=25
PGBOUNCER_RESERVE_POOL_SIZE=5

# --- SERVER PORTS ---
PORT=3001                # VRS main server
TWILIO_PORT=3002         # Twilio voice server
OPS_PORT=3003            # Ops / admin server

# --- CORS ---
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:8080,https://localhost:8080,http://localhost:3002,http://localhost:3003,http://localhost:3001,http://138.197.121.127,https://138.197.121.127,http://vrs.malkacomm.com,https://vrs.malkacomm.com,http://vri.malkacomm.com,https://vri.malkacomm.com,http://app.malkacomm.com,https://app.malkacomm.com,http://www.malkavrs.com,https://www.malkavrs.com,http://vri.maplecomm.ca,https://vri.maplecomm.ca

# --- OPS SERVER ---
NODE_ENV=development
ENABLE_BOOTSTRAP_SUPERADMIN=true
VRS_BOOTSTRAP_SUPERADMIN_USERNAME=superadmin
VRS_BOOTSTRAP_SUPERADMIN_NAME=Malka Superadmin
OPS_DATABASE_URL=postgresql://malka:malka@pgbouncer:6432/malka_vrs

# --- LEGACY ADMIN LOGIN (vrs-server) ---
# Set to "true" to re-enable the old /api/admin/login endpoint.
ENABLE_LEGACY_ADMIN_LOGIN=false

# --- USER DIRECTORY (optional JSON blob for initial accounts) ---
# VRS_USER_DIRECTORY_JSON=

# --- RATE LIMITING ---
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# --- BILLING (PostgreSQL + Stripe) ---
# Leave BILLING_PG_HOST empty to disable billing entirely.
BILLING_PG_HOST=
BILLING_PG_PORT=5432
BILLING_PG_DATABASE=vrs_billing
BILLING_PG_USER=vrs_billing
BILLING_PG_PASSWORD=
BILLING_PG_POOL_MAX=10
BILLING_PG_SSL=false

# Stripe integration: 'mock' for dev/test, 'live' for production
BILLING_STRIPE_MODE=mock
BILLING_STRIPE_SECRET_KEY=
BILLING_STRIPE_WEBHOOK_SECRET=

# Default per-minute rates (fallback when no active rate tier exists)
BILLING_DEFAULT_VRS_RATE=3.50
BILLING_DEFAULT_VRI_RATE=4.95

# --- EMAIL (password reset via SMTP) ---
# Leave SMTP_HOST empty to disable email sending (reset URLs logged to console in dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@malkavrs.com
RESET_BASE_URL=http://localhost:8080/client-profile.html
