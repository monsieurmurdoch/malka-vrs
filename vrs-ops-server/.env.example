# VRS Ops Server Configuration

# Server
PORT=3003
NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=vrs-ops-server

# Security — shared JWT secret (REQUIRED, app will not start without it)
VRS_SHARED_JWT_SECRET=
VRS_JWT_SECRET_MALKA=
VRS_JWT_SECRET_MAPLE=

# PostgreSQL persistence (REQUIRED for shared admin/dashboard state)
OPS_DATABASE_URL=postgresql://malka:malka@pgbouncer:6432/malka_vrs
OPS_MIGRATION_DATABASE_URL=postgresql://malka:malka@postgres:5432/malka_vrs

# Bootstrap superadmin (REQUIRED)
VRS_BOOTSTRAP_SUPERADMIN_PASSWORD=
VRS_BOOTSTRAP_SUPERADMIN_USERNAME=superadmin
VRS_BOOTSTRAP_SUPERADMIN_NAME=Malka Superadmin
ENABLE_BOOTSTRAP_SUPERADMIN=true

# CORS
CORS_ORIGIN=http://localhost:8080
