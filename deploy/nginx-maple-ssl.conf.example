# Enable this server block inside deploy/nginx.conf only after:
# 1. vri.maplecomm.ca resolves to the droplet IP.
# 2. Let's Encrypt has issued /etc/letsencrypt/live/vri.maplecomm.ca.

server {
    listen 443 ssl http2;
    server_name vri.maplecomm.ca;

    ssl_certificate /etc/letsencrypt/live/vri.maplecomm.ca/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/vri.maplecomm.ca/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    set $vrs_upstream http://vrs-maple:3001;
    set $ops_upstream http://ops:3003;
    set $twilio_upstream http://twilio:3002;
    set $prosody_http_upstream http://prosody:5280;

    location /api/ {
        proxy_pass $vrs_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /ws {
        proxy_pass $vrs_upstream;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 86400;
    }

    location /ops/ {
        proxy_pass $ops_upstream/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /twilio/ {
        proxy_pass $twilio_upstream/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /http-bind {
        proxy_pass $prosody_http_upstream/http-bind;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /xmpp-websocket {
        proxy_pass $prosody_http_upstream/xmpp-websocket;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 86400;
    }

    location / {
        proxy_pass $vrs_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    client_max_body_size 10M;
}
