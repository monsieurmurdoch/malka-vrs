# ============================================================
# MalkaVRS Staging Environment Configuration
# Copy to .env.staging on the staging host. Do not reuse production
# secrets, databases, Stripe keys, Twilio numbers, buckets, or domains.
# ============================================================

# --- Runtime ---
NODE_ENV=staging
LOG_LEVEL=info
DOMAIN=staging-vrs.malkacomm.com
DROPLET_PUBLIC_IP=203.0.113.10
JITSI_DOMAIN=meet.jitsi

# --- TURN/coturn staging fallback ---
# Use a staging-only shared secret and staging TURN DNS name. Do not reuse
# production TURN_SECRET. Enable with: docker compose --profile turn ...
TURN_HOST=turn-staging-vrs.malkacomm.com
TURN_REALM=staging-vrs.malkacomm.com
TURN_SECRET=
TURN_PORT=3478
TURN_TRANSPORT=udp,tcp
TURN_RELAY_MIN_PORT=49160
TURN_RELAY_MAX_PORT=49200
TURNS_HOST=
TURNS_PORT=5349

# --- Auth / JWT ---
# Generate unique staging-only values:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
VRS_SHARED_JWT_SECRET=
VRS_JWT_SECRET_MALKA=
VRS_JWT_SECRET_MAPLE=
ENABLE_BOOTSTRAP_SUPERADMIN=true
VRS_BOOTSTRAP_SUPERADMIN_USERNAME=staging.superadmin
VRS_BOOTSTRAP_SUPERADMIN_NAME=Staging Superadmin
VRS_BOOTSTRAP_SUPERADMIN_PASSWORD=
ENABLE_LEGACY_ADMIN_LOGIN=false

# --- PostgreSQL / PgBouncer ---
PGUSER=malka_staging
PGPASSWORD=
PGDATABASE=malka_vrs_staging
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=120
PGBOUNCER_DEFAULT_POOL_SIZE=15
PGBOUNCER_RESERVE_POOL_SIZE=3
# Host-side scripts use the published staging-only ports below. Container
# runtime URLs are overridden by docker-compose.staging.yml to use service names.
DATABASE_URL=postgresql://malka_staging:replace_me@127.0.0.1:56432/malka_vrs_staging
OPS_DATABASE_URL=postgresql://malka_staging:replace_me@127.0.0.1:56432/malka_vrs_staging
MIGRATION_DATABASE_URL=postgresql://malka_staging:replace_me@127.0.0.1:55432/malka_vrs_staging
OPS_MIGRATION_DATABASE_URL=postgresql://malka_staging:replace_me@127.0.0.1:55432/malka_vrs_staging
REDIS_URL=redis://redis:6379
REDIS_COMMAND_TIMEOUT_MS=500
REDIS_RATE_LIMIT_PREFIX=vrs:rate-limit
REDIS_SMS_RATE_LIMIT_PREFIX=vrs:rate-limit:sms-otp

# --- Public origins / base URLs ---
CORS_ORIGINS=https://staging-vrs.malkacomm.com,https://staging-vri.malkacomm.com,https://staging-admin.malkacomm.com,https://staging-vri.maplecomm.ca
WEBHOOK_BASE_URL=https://staging-vrs.malkacomm.com/twilio
RESET_BASE_URL=https://staging-vrs.malkacomm.com/client-profile.html

# --- Billing / Stripe test mode ---
BILLING_PG_HOST=postgres
BILLING_PG_PORT=5432
BILLING_PG_DATABASE=malka_vrs_staging
BILLING_PG_USER=malka_staging
BILLING_PG_PASSWORD=
BILLING_PG_POOL_MAX=10
BILLING_PG_SSL=false
BILLING_STRIPE_MODE=test
BILLING_STRIPE_SECRET_KEY=sk_test_replace_me
BILLING_STRIPE_WEBHOOK_SECRET=whsec_test_replace_me
BILLING_DEFAULT_VRS_RATE=3.50
BILLING_DEFAULT_VRI_RATE=4.95

# --- Twilio staging/test path ---
# Prefer Twilio test credentials or a sandbox/staging project. Leave empty to
# keep phone/SMS features unavailable during non-phone staging tests.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_CALL_RATE_LIMIT_WINDOW_MS=60000
TWILIO_CALL_RATE_LIMIT_MAX=5

# --- Optional email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=staging-noreply@malkacomm.com
